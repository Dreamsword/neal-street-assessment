user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent"';

    access_log /var/log/nginx/access.log main;

    sendfile        on;
    keepalive_timeout 65;

    # Hide nginx version in response headers
    server_tokens off;

    server {
        listen 80 default_server;
        server_name _;

        # Health endpoint — returns static JSON
        location /healthz {
            alias /usr/share/nginx/html/health.json;
            default_type application/json;
            add_header Cache-Control "no-cache, no-store";
        }

        # Root redirects to health for simplicity
        location / {
            return 200 '{"service":"{{ project | default("rewards") }}","status":"ok"}';
            default_type application/json;
        }

        # Deny access to dot-files
        location ~ /\. {
            deny all;
        }
    }
}
